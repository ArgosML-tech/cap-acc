'use strict';
const cds = require('@sap/cds');

const app = cds.test(__dirname + '/..');
app.axios.defaults.auth = { username: 'admin', password: '' };
const { POST, GET, expect } = app;

const BASE = '/odata/v4/<%= entity %>/<%= Entity %>';

describe('<%= Entity %>Service', () => {

  // ── draft lifecycle ──────────────────────────────────────────────────────────

  it('creates a draft', async () => {
    const { data } = await POST(BASE, { title: 'Test <%= Entity %>' });
    expect(data.IsActiveEntity).to.be.false;
    expect(data.ID).to.exist;
    expect(data.status).to.equal('DRAFT');
  });

  it('activates a draft', async () => {
    const { data: draft } = await POST(BASE, { title: 'Activation Test' });
    const { data: active } = await POST(
      `${BASE}(ID=${draft.ID},IsActiveEntity=false)/draftActivate`
    );
    expect(active.IsActiveEntity).to.be.true;
    expect(active.status).to.equal('DRAFT');
  });

  it('reads active entities', async () => {
    const { data } = await GET(`${BASE}?$filter=IsActiveEntity eq true`);
    expect(data.value).to.be.an('array');
  });

  // ── validation (fires on draftActivate, not on draft creation) ──────────────

  it('rejects whitespace-only title on activate', async () => {
    // @mandatory catches empty string; use whitespace-only to hit our custom handler
    const { data: draft } = await POST(BASE, { title: '   ' });
    const err = await POST(
      `${BASE}(ID=${draft.ID},IsActiveEntity=false)/draftActivate`
    ).then(() => null, (e) => e);
    expect(err).to.exist;
    expect(err.message).to.match(/title/i);
  });

  it('rejects priority out of range on activate', async () => {
    const { data: draft } = await POST(BASE, { title: 'Valid', priority: 0 });
    const err = await POST(
      `${BASE}(ID=${draft.ID},IsActiveEntity=false)/draftActivate`
    ).then(() => null, (e) => e);
    expect(err).to.exist;
    expect(err.message).to.match(/priority/i);
  });

  // ── action: submit ───────────────────────────────────────────────────────────

  it('submits an active entity', async () => {
    const { data: draft } = await POST(BASE, { title: 'Ready to submit' });
    await POST(`${BASE}(ID=${draft.ID},IsActiveEntity=false)/draftActivate`);

    const { data: submitted } = await POST(
      `/odata/v4/<%= entity %>/submit`,
      { id: draft.ID }
    );
    expect(submitted.status).to.equal('SUBMITTED');
  });

  it('rejects submit when entity is already SUBMITTED', async () => {
    const { data: draft } = await POST(BASE, { title: 'Double submit' });
    await POST(`${BASE}(ID=${draft.ID},IsActiveEntity=false)/draftActivate`);
    await POST(`/odata/v4/<%= entity %>/submit`, { id: draft.ID });

    const err = await POST(
      `/odata/v4/<%= entity %>/submit`,
      { id: draft.ID }
    ).then(() => null, (e) => e);
    expect(err).to.exist;
    expect(err.message).to.match(/submit|status/i);
  });

  it('rejects submit for non-existent entity', async () => {
    const err = await POST(
      `/odata/v4/<%= entity %>/submit`,
      { id: '00000000-0000-0000-0000-000000000000' }
    ).then(() => null, (e) => e);
    expect(err).to.exist;
  });
});
