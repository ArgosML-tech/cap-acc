'use strict';
const cds = require('@sap/cds');
// const { createLogger, ApplicationError } = require('@argos/cap-lib');
// const log = createLogger('IntegrationService');

// Production hardening — security headers + health endpoints
// (Inline equivalent of @argos/cap-ops. Replace with the package once published.)
cds.on('bootstrap', (app) => {
  app.use((_req, res, next) => {
    res.setHeader('Strict-Transport-Security', 'max-age=31536000; includeSubDomains');
    res.setHeader('X-Content-Type-Options', 'nosniff');
    res.setHeader('X-Frame-Options', 'DENY');
    res.setHeader('Referrer-Policy', 'no-referrer');
    res.setHeader("Content-Security-Policy", "default-src 'self'; frame-ancestors 'none'");
    next();
  });

  app.get('/health', (_req, res) => {
    res.json({ status: 'UP', timestamp: new Date().toISOString() });
  });

  app.get('/ready', async (_req, res) => {
    try {
      await cds.run('SELECT 1');
      res.json({ status: 'READY', db: 'connected' });
    } catch (err) {
      res.status(503).json({ status: 'NOT_READY', reason: err.message });
    }
  });
});

module.exports = class IntegrationService extends cds.ApplicationService {
  async init() {
    const { IntegrationItems } = this.entities;

    this.on('process', async (req) => {
      const { id } = req.data;
      // log.info('Processing item', { id, user: req.user?.id });

      const item = await SELECT.one.from(IntegrationItems).where({ ID: id });
      if (!item) return req.error(404, `IntegrationItem ${id} not found`);
      if (item.status === 'PROCESSED') {
        return req.error(409, `Item ${id} is already processed`);
      }

      await UPDATE(IntegrationItems)
        .where({ ID: id })
        .with({ status: 'PROCESSED', processedAt: new Date().toISOString() });

      return SELECT.one.from(IntegrationItems).where({ ID: id });
    });

    this.before('CREATE', IntegrationItems, (req) => {
      req.data.status ??= 'PENDING';
    });

    return super.init();
  }
};
